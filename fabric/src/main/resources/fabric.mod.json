{
	"schemaVersion": 1,
	"id": "simplegunpowder",
	"version": "${version}",
	"name": "Simple Gunpowder",
	"description": "A lightweight mod that adds gunpowder recipes and villager trades for easier gunpowder acquisition.",
	"authors": [
		"3C Team"
	],
	"contact": {
		"sources": "https://github.com/3ColumnsC/SimpleGunpowder"
	},
	"license": "MIT",
	"icon": "assets/simplegunpowder/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"com.threecolumnsstudio.simplegunpowder.fabric.SimpleGunpowderFabric"
		]
	},
	"mixins": [
		"simplegunpowder.mixins.json"
	],
	"depends": {
		"fabricloader": ">=0.18.6",
		"minecraft": "~1.21.11",
		"java": ">=21",
		"fabric-api": ">=0.141.3"
	}
}